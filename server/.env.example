# PostgreSQL connection string
# Local dev example: postgresql://postgres:postgres@localhost:5432/prepshot_db
# Production (Coolify): use the internal connection string from the Coolify DB resource
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prepshot_db

# JWT signing secret — generate with: openssl rand -base64 32
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# Server port (default 3100)
PORT=3100

# Set to "production" when deploying
NODE_ENV=development
